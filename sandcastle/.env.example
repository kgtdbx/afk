# Claude Code OAuth token (from your Max/Pro subscription)
# Run: claude setup-token
# Then copy the token here
CLAUDE_CODE_OAUTH_TOKEN=

# GitHub personal access token (from gh auth)
# Run: gh auth token
# Then copy the token here
GH_TOKEN=

# GitHub repo (owner/name) — ensures gh commands target your fork, not upstream
# Example: kgtdbx/cohort-003-project-kgt
GH_REPO=
